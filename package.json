{
  "name": "defisecure-monorepo",
  "private": true,
  "version": "1.0.0",
  "description": "DeFiSecure – AI-Powered Decentralized Financial Transaction System (full-stack Web3 + PoW simulation + AI fraud detection).",
  "workspaces": [
    "frontend",
    "backend",
    "smart-contracts",
    "blockchain-engine"
  ],
  "scripts": {
    "install:all": "npm install",
    "dev": "npm run dev --workspace backend",
    "dev:frontend": "npm run dev --workspace frontend",
    "dev:backend": "npm run dev --workspace backend",
    "dev:engine": "npm run dev --workspace blockchain-engine",
    "contracts:compile": "npm run compile --workspace smart-contracts",
    "contracts:test": "npm run test --workspace smart-contracts",
    "contracts:node": "npm run node --workspace smart-contracts",
    "contracts:deploy:local": "npm run deploy:local --workspace smart-contracts",
    "lint": "npm run lint --workspace frontend && npm run lint --workspace backend",
    "legacy:dev:client": "npm run dev --prefix client",
    "legacy:contracts:compile": "npm run compile --prefix blockchain",
    "legacy:contracts:node": "npm run node --prefix blockchain",
    "legacy:contracts:deploy:local": "npm run deploy:local --prefix blockchain"
  },
  "license": "MIT"
}
